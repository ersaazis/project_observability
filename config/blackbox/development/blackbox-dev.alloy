// BLACKBOX ERP
prometheus.exporter.blackbox "uptime_check_dev" {
  config_file = "/ops/alloy-service/blackbox/blackbox_modules.yml"
  
  
  // ======================
  // SAMPLE: Checker Service (URL/HTTP)
  // ======================
  // target {
  //   name = "Sample_API_Service"
  //   address = "https://api.example.com/health"
  //   module  = "http_2xx"
  //   labels = {
  //     "name" = "Project Name | API Service",
  //     "job" = "integrations/blackbox",
  //     "env" = "development",
  //     "group" = "SampleGroup"
  //   }
  // }

  // ======================
  // SAMPLE: Checker Server (Ping/ICMP)
  // ======================
  // target {
  //   name = "Sample_DB_Server"
  //   address = "192.168.1.100"
  //   module  = "icmp"
  //   labels = {
  //     "name" = "Project Name | DB Server",
  //     "job" = "integrations/blackbox",
  //     "env" = "development",
  //     "group" = "SampleGroup"
  //   }
  // }

  // ======================
  // SAMPLE: Database / Specific Port (TCP)
  // ======================
  // target {
  //   name = "Sample_MySQL_Database"
  //   address = "192.168.1.200:3306"
  //   module  = "tcp_connect"
  //   labels = {
  //     "name" = "Project Name | MySQL DB",
  //     "job" = "integrations/blackbox",
  //     "env" = "development",
  //     "group" = "DatabaseGroup"
  //   }
  // }
}
discovery.relabel "uptime_check_dev" {
  targets = prometheus.exporter.blackbox.uptime_check_dev.targets

  rule {
    source_labels = ["__param_target"]
    target_label = "instance"
  }
}
prometheus.scrape "uptime_check_dev" {
  targets         = discovery.relabel.uptime_check_dev.output
  forward_to      = [prometheus.remote_write.mimir.receiver]
  scrape_interval = "1m"
}
